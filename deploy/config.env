# ─────────────────────────────────────────────────────────────────
#  Configuración del deploy — editá estas variables antes de correr
#  los scripts de deploy.
# ─────────────────────────────────────────────────────────────────

# Región de AWS donde se despliega todo
AWS_REGION="us-east-1"

# Nombre del bucket S3 donde se guardan los reportes JSON
# IMPORTANTE: los nombres de bucket son globales en AWS — debe ser único
S3_BUCKET_NAME="iam-analyzer-reports-$(aws sts get-caller-identity --query Account --output text 2>/dev/null)"

# Email que recibirá las alertas cuando se detecten hallazgos CRÍTICOS
ALERT_EMAIL="tu-email@ejemplo.com"

# Severidad mínima a reportar (low | medium | high | critical)
MIN_SEVERITY="low"

# Nombre de la función Lambda
LAMBDA_FUNCTION_NAME="iam-policy-analyzer"

# Nombre del IAM Role que usará Lambda
LAMBDA_ROLE_NAME="iam-analyzer-lambda-role"

# Nombre del topic SNS para alertas
SNS_TOPIC_NAME="iam-analyzer-alerts"

# Expresión cron de EventBridge (UTC)
# Ejemplos:
#   Todos los días a las 8am UTC:  cron(0 8 * * ? *)
#   Cada lunes a las 6am UTC:      cron(0 6 ? * MON *)
#   Cada hora:                     rate(1 hour)
SCHEDULE_EXPRESSION="cron(0 8 * * ? *)"
